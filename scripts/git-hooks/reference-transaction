#!/usr/bin/env bash
# reference-transaction — enforce per-session worktree isolation in the shared
# connector clone, with an ATOMIC veto (AI-2481 / INF-17, follow-up to AI-2475).
#
# The AI-2475 bug: many agent sessions share ONE connector clone — one working
# tree, one HEAD. A concurrent session detaching HEAD onto a commit / remote ref,
# or a `git reset --hard`, silently reverts another session's checkout mid-edit
# (reflog caught HEAD detaching onto an unrelated ref, and a tracked file reverting
# under an active session). Worktrees fix it — each session gets its own HEAD —
# but nothing *enforced* them.
#
# This hook makes the destructive cases structural. In the PRIMARY working tree it
# VETOES a HEAD move that is NOT a commit/pull on the current branch — i.e. a
# detached checkout (`git checkout <commit|origin/branch|--detach>`) or a
# `git reset` onto a different commit. It ALLOWS, deliberately:
#   - commits and `git pull`/ff-merge on the current branch (HEAD and its branch
#     ref advance together to the same SHA)
#   - `git commit --amend` (rewrites the current commit in place; the new commit
#     is a sibling of old HEAD and the amend does not touch the working tree)
#   - `git worktree add` and all HEAD moves INSIDE a linked worktree (the point)
#   - branch create/delete and fetches (refs/heads,* refs/remotes/* — not HEAD)
#
# KNOWN LIMITATION (measured, AI-2481): a plain `git checkout <existing-local-
# branch>` only retargets the HEAD symref and fires NO reference-transaction
# event, so this hook cannot veto it. That case is far less dangerous — git
# refuses the switch if it would overwrite dirty tracked files — and the workflow
# guidance + CONTRIBUTING already steer sessions to worktrees. This hook is
# defense-in-depth for the destructive detach/reset yanks, not a total interlock.
#
# ATOMIC VETO (INF-17). git updates the index + working tree to the target BEFORE
# the ref transaction fires, so a naive veto aborts the HEAD move but leaves the
# tree + index swapped to foreign content — a "failed" checkout that silently
# dirties the shared clone. INF-17: the operator sees `fatal: ref updates aborted
# by hook`, reads it as a clean no-op, and walks away from a staged pile of another
# ref's files; a later `git commit` in any session then captures the foreign
# content with no prompt. This hook closes that hole. The reference-transaction
# `aborted` phase fires AFTER git has released the index lock, so we restore the
# exact paths the checkout swapped — the staged delta vs HEAD — back to HEAD there.
# Net effect: HEAD never moved AND the index + working tree are exactly as before.
# The veto is atomic.
#
# The restore is SCOPED to the staged delta (not a blanket `git restore .`) on
# purpose: a concurrent session's UNSTAGED edit to an unrelated file must never be
# clobbered. `git checkout` refuses to run over dirty tracked files, so the staged
# delta is exactly this checkout's own swap and nothing else — an unstaged-only
# edit (worktree≠index, index==HEAD) is not in the delta and is left untouched. If
# the auto-restore itself fails, the veto message prints the manual command and we
# are no worse off than the old non-atomic behavior.
#
# WHY NOT MAKE THE PRIMARY TREE FULLY READ-ONLY (INF-17 AC, considered & rejected):
# commits and ff-pulls on the current branch are legitimate primary-tree operations
# (deploys pull here), and the hook already allows exactly those while vetoing the
# yanks. A blanket read-only lock would break the sanctioned commit/pull path. The
# atomic veto + "work in a worktree" guidance gives the same protection without that
# cost; `git worktree add` remains the only sanctioned path for detached/PR checkouts
# and is unaffected by this hook.
#
# Escape hatch: OC_GIT_UNSAFE=1 (human, having read the above).
set -uo pipefail

state="${1:-}"
# Act in "prepared" (cast the veto) and "aborted" (self-restore after the veto
# rolled the ref back). Ignore "committed" and any unknown phase.
case "$state" in prepared|aborted) ;; *) exit 0 ;; esac
[ "${OC_GIT_UNSAFE:-}" = "1" ] && exit 0

# Enforce only in the PRIMARY tree. A linked worktree's git dir is under
# <common>/worktrees/<name>; the primary tree's git dir IS the common dir.
GITDIR="$(git rev-parse --absolute-git-dir 2>/dev/null || echo "")"
case "$GITDIR" in
  */worktrees/*) exit 0 ;;
esac

ZERO="0000000000000000000000000000000000000000"

# Buffer the whole transaction: HEAD's new SHA is only safe if some branch ref in
# the SAME transaction advances to that same SHA (commit / reset-on-branch / ff).
# git replays the same ref lines on stdin in BOTH the prepared and aborted phases,
# so the veto decision below is identical across the two callbacks.
head_old="" head_new="" head_seen=""
branch_news=""
while read -r _old _new ref; do
  case "$ref" in
    HEAD)
      head_seen=1; head_old="$_old"; head_new="$_new" ;;
    refs/heads/*)
      branch_news="$branch_news $_new" ;;
  esac
done

# is_yank: return 0 when this transaction is a destructive HEAD yank to veto, 1 to
# allow. Encapsulates the full allow-matrix so the prepared (veto) and aborted
# (restore) phases agree exactly on which transactions they act upon.
is_yank() {
  [ -n "$head_seen" ] || return 1
  # No-op HEAD update — allow.
  [ "$head_old" = "$head_new" ] && return 1
  # HEAD advanced together with a branch ref to the same SHA → commit / pull /
  # reset on the current branch. The session moved its OWN branch; allow.
  case " $branch_news " in
    *" $head_new "*)
      # A branch advanced to HEAD's new SHA. Allow only a FORWARD move (old is an
      # ancestor of new) — that is a commit, ff-pull, or merge on the current
      # branch. A sideways/backward move (reset --hard onto another commit, rebase)
      # is destructive to the shared tree and is refused. Fail open only if
      # merge-base cannot run (rc>1) so a legitimate commit is never blocked.
      [ "$head_old" = "$ZERO" ] && return 1
      git merge-base --is-ancestor "$head_old" "$head_new" 2>/dev/null
      rc=$?
      [ "$rc" -eq 0 ] && return 1     # forward move — allow
      [ "$rc" -gt 1 ] && return 1     # merge-base errored — fail open (don't block commits)
      # rc==1: not a forward move. Distinguish `git commit --amend` — the new commit
      # is a SIBLING of old HEAD (shares its parent) and the amend does NOT touch the
      # working tree, so it is not a yank — from a destructive sideways `reset --hard`.
      # Allow only when the first parents match. A reset onto an older/unrelated commit
      # has a different parent and still falls through to the veto. (Residual: a reset
      # --hard onto an exact sibling of HEAD is indistinguishable from an amend from
      # ref data alone and is allowed — an exotic case; documented defense-in-depth.)
      old_par="$(git rev-parse --verify -q "${head_old}^" 2>/dev/null || echo "")"
      new_par="$(git rev-parse --verify -q "${head_new}^" 2>/dev/null || echo "")"
      [ -n "$old_par" ] && [ "$old_par" = "$new_par" ] && return 1
      ;;
  esac
  # HEAD moved to a commit with no branch following it → detached checkout or a
  # reset onto another commit. This is the yank.
  return 0
}

is_yank || exit 0

if [ "$state" = "aborted" ]; then
  # The prepared-phase veto already aborted the HEAD move — HEAD is intact. git
  # swapped the index + working tree to the target BEFORE the ref txn, so undo
  # EXACTLY those paths (the staged delta vs HEAD) back to HEAD, and no others.
  # Scoping to the staged delta guarantees a concurrent session's UNSTAGED edit to
  # an unrelated file is never touched (see header). This runs after git released
  # the index lock, and `git restore` moves no ref, so it does not re-enter here.
  mapfile -t swapped < <(git diff --cached --name-only -z HEAD 2>/dev/null | tr '\0' '\n')
  if [ "${#swapped[@]}" -eq 0 ]; then exit 0; fi
  err="$(git rev-parse --git-dir 2>/dev/null)/reftxn-restore.$$.err"
  if git restore --staged --worktree --source=HEAD -- "${swapped[@]}" 2>"$err"; then
    echo "  [reference-transaction] auto-restored ${#swapped[@]} path(s) to HEAD — index + working tree are clean; nothing was left staged." >&2
    rm -f "$err"
  else
    echo "  [reference-transaction] AUTO-RESTORE FAILED — the tree is still swapped to foreign content. Restore it by hand:" >&2
    echo "      git restore --staged --worktree ." >&2
    sed 's/^/      /' "$err" >&2 2>/dev/null || true
    rm -f "$err"
  fi
  exit 0
fi

# state == prepared: cast the veto.
cat >&2 <<'MSG'
──────────────────────────────────────────────────────────────────────────
  Blocked: detaching/moving HEAD in the shared connector clone's PRIMARY tree.

  This clone is shared by every concurrent agent session. Detaching HEAD onto a
  commit or remote ref (git checkout <commit|origin/branch|--detach>), or a
  git reset onto a different commit, is exactly the race that silently reverted
  another session's checkout in AI-2475.

  Work in an isolated worktree instead:

    cd "$(scripts/connector-worktree.sh <branch> [base-ref])"

  You get your own HEAD, index, and files (sharing only .git/objects); this hook
  does not touch worktree HEAD moves. Clean up when done:

    scripts/connector-worktree-remove.sh <branch>

  HEAD was NOT moved — the shared checkout pointer is intact. git DID swap your
  index + working tree to the target ref before this veto fired; the hook restores
  them to HEAD automatically in the transaction-abort step that follows (look for a
  "[reference-transaction] auto-restored ..." line just below). If that line reports
  a FAILURE instead, undo the swap by hand with:

    git restore --staged --worktree .

  Human override, having read the above: OC_GIT_UNSAFE=1 git ... (AI-2481 / INF-17)
──────────────────────────────────────────────────────────────────────────
MSG
exit 1
