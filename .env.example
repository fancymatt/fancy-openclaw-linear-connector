# Linear webhook secret for signature verification
LINEAR_WEBHOOK_SECRET=

# OpenClaw gateway URL
OPENCLAW_GATEWAY_URL=http://localhost:3000

# Service port
PORT=3100

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Optional: encrypt agents.json at rest with AES-256-GCM.
# Value must be a base64-encoded 32-byte key. File variant may point to a file containing that value.
# LINEAR_CONNECTOR_ENCRYPTION_KEY=
# LINEAR_CONNECTOR_ENCRYPTION_KEY_FILE=

# Optional: isolated session mode.
# When both are set, each webhook fires into a fresh ephemeral agent turn (POST /hooks/agent)
# instead of routing to the agent's main Telegram session.
# Omit (or leave blank) to keep the default CLI routing behaviour.
# OPENCLAW_HOOKS_URL=http://localhost:18789/hooks/agent
# OPENCLAW_HOOKS_TOKEN=<token from openclaw.json hooks.token>

# Linear user ID of the human owner — used by stale-session recovery to assign needs-human
# tickets (C1/C3/C5/C6/C-UNK) to the owner for review instead of re-dispatching to a bot.
# STALE_HUMAN_ASSIGNEE_LINEAR_ID=<linear-user-uuid>

# ── Phase 2: escalation gate (design.md §11, §13) ──────────────────────────
# Path to the canonical Nakazawa capability policy YAML used by the proxy to
# resolve body→container→capabilities for enforcement rules.
# Defaults to $HOME/obsidian-vault/ai-systems/projects/fleet-orchestration-redesign/config/capability-policy.yaml
# CAPABILITY_POLICY_PATH=

# ── Phase 0B: connector-as-proxy (design.md §4.6) ──────────────────────────
# The connector exposes POST /proxy/graphql which agents route their Linear CLI
# calls through instead of hitting api.linear.app directly.  v0 is transparent
# pass-through; future phases add per-step instruction injection and command
# validation.  Configure the Linear CLI with LINEAR_PROXY_URL pointing at this
# connector's /proxy/graphql endpoint so Nakazawa agents use the proxy path.
# ILL fleet deployments do NOT set this and are unaffected.
#
# Example (set in each Nakazawa agent's environment):
#   LINEAR_PROXY_URL=http://localhost:3100/proxy/graphql

# ── Phase 6.5 / H-3: Engine stall detection SLAs ─────────────────────────────
# Comma-separated list of STATE:MAX_DURATION in milliseconds.
# States: thinking, doing, managing (and any custom state you add).
# Example: THINKING:3600000,DOING:14400000,MANAGING:86400000
# Defaults: thinking=1h, doing=4h, managing=24h if not set.
# ENGINE_STALL_SLAS=
